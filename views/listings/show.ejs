<% layout("/layouts/boilerplate") %>
  <body>
    <h3>Listing Details:</h3>
    <% if(listing.image && listing.image.url) { %>
      <div style="margin-bottom: 20px;">
        <img src="<%=listing.image.url%>" alt="<%=listing.title%>" onerror="this.src='https://thumbs.dreamstime.com/b/city-park-pond-shore-alley-20238927.jpg'" style="max-width: 100%; height: auto;">
      </div>
    <% } else { %>
      <div style="margin-bottom: 20px;">
        <img src="https://thumbs.dreamstime.com/b/city-park-pond-shore-alley-20238927.jpg" alt="Fallback image" style="max-width: 100%; height: auto;">
      </div>
    <% } %>
    <ul>
      <li><%=listing.title%></li>
      <li><%=listing.description%></li>
      <li> &#8377; <%=listing.price.toLocaleString('en-IN')%></li>
      <li><%=listing.location%></li>
      <li><%=listing.country%></li>
    </ul>

    <a href="/listings/<%=listing._id%>/edit">Edit This Listing</a>
    <form action="/listings/<%=listing._id%>?_method=DELETE" method="POST">
      <button>Delete</button>
    </form>
  </body>
