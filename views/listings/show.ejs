<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-2">
    <h3>Listing Details</h3>
  </div>
  <div class="card col-6 offset-2">
    <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="..." />
    <div class="card-body">
      <p class="card-text">
        <b><%=listing.title%></b> <br />
        <%=listing.description%>
        <br />
        &#8377; <%=listing.price.toLocaleString('en-IN')%> /night <br />
        <%=listing.location%>
        <br />
        <%=listing.country%>
        <br />
      </p>
    </div>
  </div>
  <!-- <% if(listing.image && listing.image.url) { %>
      <div style="margin-bottom: 20px;">
        <img src="<%=listing.image.url%>" alt="<%=listing.title%>" onerror="this.src='https://thumbs.dreamstime.com/b/city-park-pond-shore-alley-20238927.jpg'" style="max-width: 100%; height: auto;">
      </div>
    <% } else { %>
      <div style="margin-bottom: 20px;">
        <img src="https://thumbs.dreamstime.com/b/city-park-pond-shore-alley-20238927.jpg" alt="Fallback image" style="max-width: 100%; height: auto;">
      </div>
    <% } %> -->

  <div class="btns">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 offset-2 edit-btn">Edit</a>
 
  
    <form action="/listings/<%=listing._id%>?_method=DELETE" method="POST">
      <button class="btn btn-dark offset-4">Delete</button>
    </form>
  </div>
</div>
